# Copy this file to .env.onprem before running docker-compose.onprem.yml.

# PostgreSQL connection for the app container.
DATABASE_URL=postgresql://postgres:change-me@db:5432/vectordb

# Optional plain PostgreSQL target for inserting the same pipeline output.
# Use the Server B address reachable from the app container.
# Leave empty to disable mirroring.
MIRROR_DATABASE_URL=

# Offline embedding model path mounted from ./models -> /models.
EMBEDDING_MODEL=/models/bge-m3
EMBEDDING_DEVICE=cpu

# Chunking and processing options.
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
BATCH_SIZE=32
IVFFLAT_PROBES=200
LOG_LEVEL=INFO
EXCLUDE_BOILERPLATE_TABLE=false

# Data and metadata paths inside the app container.
DATA_DIRS=/app/data
METADATA_DOC_LIST=/app/metadata

# Optional preprocessing controls.
EXTRACT_HWP_IMAGES=true
CONVERT_HWPX=false
SOFFICE_PATH=/usr/bin/soffice
HWPX_CONVERT_TIMEOUT=180
